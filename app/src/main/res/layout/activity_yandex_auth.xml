<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0B0B0F">

    <WebView
        android:id="@+id/yandexAuthWebView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <ProgressBar
        android:id="@+id/yandexAuthProgress"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:indeterminate="true"
        android:progressTint="#2F80ED" />

    <LinearLayout
        android:id="@+id/yandexAuthErrorPanel"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="28dp"
        android:visibility="gone">

        <TextView
            android:id="@+id/yandexAuthErrorTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Не удалось открыть Яндекс"
            android:textColor="#F6F7FB"
            android:textSize="22sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/yandexAuthErrorText"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:gravity="center"
            android:textColor="#A7ABB8"
            android:textSize="15sp" />

        <Button
            android:id="@+id/yandexAuthRetryButton"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:layout_marginTop="24dp"
            android:background="@drawable/bg_yandex_button"
            android:text="Повторить"
            android:textAllCaps="false"
            android:textColor="#FFFFFF"
            android:textSize="16sp" />
    </LinearLayout>
</FrameLayout>
